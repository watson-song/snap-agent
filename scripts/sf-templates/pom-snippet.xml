<!--
  SnapAgent v__VERSION__ — 本地 Maven 仓库配置（CICD 无外网场景）

  将以下内容合并到宿主项目 pom.xml 的 <repositories> 和 <dependencies> 中。
  lib/ 目录需放在宿主项目根目录下（与 pom.xml 同级）。
  Maven 会从 lib/ 内的标准仓库路径解析 snap-agent 的 jar 和 pom，
  不需要访问 Maven Central 或任何外部仓库。

  ⚠ 多模块项目注意：
  必须用 ${maven.multiModuleProjectDirectory} 而非 ${project.basedir}。
  ${project.basedir} 在子模块构建时解析为子模块目录，会导致 Maven 找不到
  根目录下的 lib/，静默回退到远程仓库，CI/CD 构建报 "Could not find artifact"。
  ${maven.multiModuleProjectDirectory}（Maven 3.3.1+）始终指向项目根目录。

  ⚠ Mirror 拦截降级方案：
  如果 CICD 的 settings.xml 配置了 <mirror>（如 <mirrorOf>*</mirror> 重定向到
  Artifactory），file:// 本地文件仓库会被全局拦截，方案一不可用。
  此时使用方案二（system scope）直接从文件系统加载 JAR。
-->

<!-- ============ 方案一：file:// 文件仓库（无 mirror 拦截时首选）============ -->
<repositories>
    <repository>
        <id>snap-agent-local</id>
        <url>file://${maven.multiModuleProjectDirectory}/lib</url>
        <releases>
            <enabled>true</enabled>
            <checksumPolicy>ignore</checksumPolicy>
        </releases>
        <snapshots>
            <enabled>false</enabled>
        </snapshots>
    </repository>
</repositories>

<dependencies>
    <!-- SnapAgent Starter（会自动引入 snap-agent-core） -->
    <dependency>
        <groupId>cn.watsontech.snapagent</groupId>
        <artifactId>snap-agent-spring-boot-2x-starter</artifactId>
        <version>__VERSION__</version>
    </dependency>

    <!-- OkHttp（LLM 流式调用必需，Spring Boot 不自带，需显式声明） -->
    <!-- 如果宿主项目已有 okhttp 可跳过此依赖 -->
    <dependency>
        <groupId>com.squareup.okhttp3</groupId>
        <artifactId>okhttp</artifactId>
    </dependency>
</dependencies>

<!-- ============ 方案二：system scope（mirror 拦截时使用）============ -->
<!-- 仅当方案一不生效（CICD 日志只有 Downloading from maven: 没有 snap-agent-local:）时使用 -->
<!-- system scope 不解析传递依赖，必须显式声明 starter 和 core 两个依赖 -->
