<!--
  SnapAgent v__VERSION__ — 本地 Maven 仓库配置（CICD 无外网场景）

  将以下内容合并到宿主项目 pom.xml 的 <repositories> 和 <dependencies> 中。
  lib/ 目录需放在宿主项目根目录下（与 pom.xml 同级）。
  Maven 会从 lib/ 内的标准仓库路径解析 snap-agent 的 jar 和 pom，
  不需要访问 Maven Central 或任何外部仓库。
-->

<!-- ============ 1. 添加本地文件仓库 ============ -->
<repositories>
    <repository>
        <id>snap-agent-local</id>
        <url>file://${project.basedir}/lib</url>
        <releases>
            <enabled>true</enabled>
            <checksumPolicy>ignore</checksumPolicy>
        </releases>
        <snapshots>
            <enabled>false</enabled>
        </snapshots>
    </repository>
</repositories>

<!-- ============ 2. 添加依赖 ============ -->
<dependencies>
    <!-- SnapAgent Starter（会自动引入 snap-agent-core） -->
    <dependency>
        <groupId>com.watsontech.snapagent</groupId>
        <artifactId>snap-agent-spring-boot-2x-starter</artifactId>
        <version>__VERSION__</version>
    </dependency>

    <!-- OkHttp（LLM 流式调用必需，Spring Boot 不自带，需显式声明） -->
    <!-- 如果宿主项目已有 okhttp 可跳过此依赖 -->
    <dependency>
        <groupId>com.squareup.okhttp3</groupId>
        <artifactId>okhttp</artifactId>
    </dependency>
</dependencies>
